# AWS region for the deployment.
aws_region = "us-west-2"

# Application and environment names.
# Use tfdev to avoid name conflicts with manually created AWS resources.
app_name    = "ai-workspace"
environment = "tfdev"

# Existing SSM Parameter Store name for OpenAI API key.
# Create this manually before terraform apply.
openai_api_key_parameter_name = "/ai-workspace/OPENAI_API_KEY"

# RDS PostgreSQL configuration.
database_name     = "ai_workspace"
database_username = "postgres"

# Replace this only in local terraform.tfvars.
# Do not commit real passwords.
database_password = "replace-with-secure-password"

database_engine_version = ""

database_instance_class = "db.t4g.micro"

backend_container_port = 8000
backend_image_tag      = "latest"

ecs_cpu           = "512"
ecs_memory        = "1024"
ecs_desired_count = 1

frontend_url = "https://your-vercel-domain.vercel.app"

openai_model = "gpt-4.1-mini"